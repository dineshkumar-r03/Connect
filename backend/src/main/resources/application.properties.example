# Application
spring.application.name=connect-backend
server.port=${PORT:8090}

# Database Configuration
# In production, replace these with database environment variables:
# e.g., spring.datasource.url=${DB_URL}
spring.datasource.url=jdbc:mysql://localhost:3306/careeros?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
spring.datasource.username=YOUR_DATABASE_USERNAME
spring.datasource.password=YOUR_DATABASE_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.show-sql=true

# JWT Security
# Replace with a secure 256-bit key in production
app.jwt.secret=YOUR_SECURE_JWT_SECRET_KEY
app.jwt.expiration-ms=86400000
app.jwt.refresh-expiration-ms=604800000

# CORS
app.cors.allowed-origins=http://localhost:3000

# Gemini API Key (Configure via environment variables on Render)
gemini.api.key=${GEMINI_API_KEY:}
